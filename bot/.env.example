# Google OAuth2 credentials (from Google Cloud Console)
YOUTUBE_CLIENT_ID=your_client_id_here
YOUTUBE_CLIENT_SECRET=your_client_secret_here

# Long-lived refresh token (run scripts/get-token.ts once to generate)
YOUTUBE_REFRESH_TOKEN=your_refresh_token_here

# Anthropic API key (same one used by screwedscore.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# The bot's YouTube channel display name — used to detect when viewers address the bot
BOT_NAME=your_bot_channel_name_here
