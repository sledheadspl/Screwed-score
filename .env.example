# Supabase — use your EXISTING ContractGuard project or a new one
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — reuse same key as ContractGuard
ANTHROPIC_API_KEY=sk-ant-your-key

# ContractGuard Edge Function URL — point at your existing deployed function
CONTRACTGUARD_FUNCTION_URL=https://your-project.supabase.co/functions/v1/analyze-contract
CONTRACTGUARD_FUNCTION_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_live_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-key
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY=price_xxx

# App
NEXT_PUBLIC_APP_URL=https://getscrewedscore.com
