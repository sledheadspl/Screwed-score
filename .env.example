# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key

# ─── ContractGuard Edge Function (optional — falls back to direct Anthropic) ──
CONTRACTGUARD_FUNCTION_URL=https://your-project.supabase.co/functions/v1/analyze-contract
CONTRACTGUARD_FUNCTION_KEY=your-service-role-key

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your-key
# Secret used to sign Pro JWT cookies — generate with: openssl rand -hex 32
GSS_TOKEN_SECRET=your-random-32-byte-hex-secret
# Webhook secret from Stripe dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-key
# Price ID for the Pro monthly plan (from Stripe dashboard → Products)
GSS_STRIPE_PRICE_ID=price_xxx

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://screwedscore.com
NEXT_PUBLIC_APP_URL=https://screwedscore.com

# ─── Resend (product delivery emails) ───────────────────────────────────────
RESEND_API_KEY=re_your-api-key
# Must be a verified domain in Resend — e.g. products@screwedscore.com
RESEND_FROM_EMAIL=products@screwedscore.com

# ─── Product download URLs ───────────────────────────────────────────────────
# Set these to your actual file links (Google Drive, Dropbox, S3, etc.)
PRODUCT_LINK_CREATOR_OS=https://drive.google.com/your-link
PRODUCT_LINK_CONTENT_PIPELINE=https://drive.google.com/your-link
PRODUCT_LINK_BRAND_DEAL=https://drive.google.com/your-link
PRODUCT_LINK_REVENUE_DASHBOARD=https://drive.google.com/your-link
PRODUCT_LINK_SOCIAL_ASSETS=https://drive.google.com/your-link
PRODUCT_LINK_LAUNCH_SEQUENCE=https://drive.google.com/your-link

# ─── Analytics (optional) ────────────────────────────────────────────────────
# Google Analytics 4 measurement ID — omit to disable GA entirely
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
